---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Zapatos elegantes de mujer - Diseño exclusivas italiano, elegancia y sofisticación para la mujer moderna" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Élégance - Zapatos de Mujer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Lato:wght@300;400;500&display=swap" rel="stylesheet">
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-crema: #F8F4EE;
    --color-crema-oscuro: #E8E0D5;
    --color-dorado: #B8966B;
    --color-dorado-claro: #D4B896;
    --color-negro: #1A1A1A;
    --color-negro-suave: #2D2D2D;
    --color-gris-oscuro: #404040;
    --color-gris-medio: #6B6B6B;
    --color-gris-claro: #A0A0A0;
    --color-blanco: #FAFAFA;
    --color-blanco-puro: #FFFFFF;
    --color-rosa-suave: #F5EBE0;
    --font-titulo: 'Playfair Display', serif;
    --font-cuerpo: 'Lato', sans-serif;
    --sombra-suave: 0 4px 20px rgba(0, 0, 0, 0.08);
    --sombra-media: 0 8px 30px rgba(0, 0, 0, 0.12);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-cuerpo);
    background: var(--color-crema);
    color: var(--color-negro);
    line-height: 1.7;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-titulo);
    font-weight: 500;
    line-height: 1.3;
  }

  a {
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  ::selection {
    background: var(--color-dorado);
    color: var(--color-blanco-puro);
  }
</style>