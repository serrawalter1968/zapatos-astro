          <a href="https://tiktok.com" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
          </a>
        </div>
      </div>

      <div class="footer-links">
        <h4>Colección</h4>
        <ul>
          <li><a href="/productos">Zapatos de Fiesta</a></li>
          <li><a href="/productos">Zapatos de Cuero</a></li>
          <li><a href="/productos">Zapatillas Elegantes</a></li>
          <li><a href="/productos">Modelos Exclusivos</a></li>
        </ul>
      </div>

      <div class="footer-contact">
        <h4>Contacto</h4>
        <ul>
          <li>contacto@elegance-shoes.com</li>
          <li>+34 612 345 678</li>
          <li>Madrid, España</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {currentYear} Élégance. Calzado de mujer de diseño exclusivo.</p>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(180deg, var(--color-negro-suave) 0%, var(--color-negro) 100%);
    color: var(--color-blanco);
    margin-top: auto;
  }

  .footer-top {
    border-bottom: 1px solid rgba(184, 150, 107, 0.2);
  }

  .footer-content {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 3rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 4rem;
  }

  .footer-brand h3 {
    font-family: var(--font-titulo);
    font-size: 1.8rem;
    letter-spacing: 0.2em;
    margin-bottom: 0.8rem;
    color: var(--color-dorado);
  }

  .brand-tagline {
    font-family: var(--font-titulo);
    font-size: 1.1rem;
    font-style: italic;
    color: var(--color-blanco);
    margin-bottom: 1.2rem;
  }

  .brand-description {
    color: var(--color-gris-claro);
    font-size: 0.9rem;
    line-height: 1.8;
    max-width: 400px;
  }

  .social-icons {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .social-icons a {
    width: 40px;
    height: 40px;
    border: 1px solid var(--color-gris-medio);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gris-claro);
    transition: all 0.3s ease;
  }

  .social-icons a:hover {
    border-color: var(--color-dorado);
    color: var(--color-dorado);
    transform: translateY(-3px);
  }

  .footer-links h4,
  .footer-contact h4 {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    color: var(--color-dorado);
  }

  .footer-links ul,
  .footer-contact ul {
    list-style: none;
  }

  .footer-links li,
  .footer-contact li {
    margin-bottom: 0.9rem;
    color: var(--color-gris-claro);
    font-size: 0.9rem;
  }

  .footer-links a {
    transition: all 0.3s ease;
  }

  .footer-links a:hover {
    color: var(--color-dorado);
    padding-left: 0.5rem;
  }

  .footer-bottom {
    padding: 1.5rem 3rem;
    text-align: center;
    background: rgba(0, 0, 0, 0.3);
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: var(--color-gris-medio);
    letter-spacing: 0.1em;
  }

  @media (max-width: 900px) {
    .footer-content {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .footer-content {
      grid-template-columns: 1fr;
      padding: 3rem 1.5rem;
    }
  }
</style>