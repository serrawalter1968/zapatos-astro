---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductModal from '../components/ProductModal.astro';

const productos = [
  {
    id: 1,
    nombre: "Corazones",
    descripcion: "Zapatillas urbanas con detalle de corazón. Elegancia con un toque de ternura.",
    precio: 85,
    categoria: "Urbanas",
    imagen: "/images/zapatos 01.jpg"
  },
  {
    id: 2,
    nombre: "Urbano Black",
    descripcion: "Zapatillas urbanas negras. Sofisticación minimalista para el día a día.",
    precio: 75,
    categoria: "Urbanas",
    imagen: "/images/zapatos 02.jpg"
  },
  {
    id: 3,
    nombre: "Andy",
    descripcion: "Diseño clásico con toque moderno. El equilibrio perfecto entre tradición y tendencia.",
    precio: 95,
    categoria: "Clásicas",
    imagen: "/images/zapatos 03.jpg"
  },
  {
    id: 4,
    nombre: "Peques",
    descripcion: "Zapatillas cómodas para el día a día. Estilo effortless y comodidad asegurada.",
    precio: 65,
    categoria: "Casual",
    imagen: "/images/zapatos 04.jpg"
  },
  {
    id: 5,
    nombre: "Urbano Cuero",
    descripcion: "Cuero legítimo de alta calidad. La elección sofisticada para mujer segura.",
    precio: 110,
    categoria: "Cuero",
    imagen: "/images/zapatos 05.jpg"
  },
  {
    id: 6,
    nombre: "Love",
    descripcion: "Diseño exclusivo con corazón. Para la mujer que ama la moda con pasión.",
    precio: 89,
    categoria: "Especial",
    imagen: "/images/zapatos 06.jpg"
  },
  {
    id: 7,
    nombre: "Floter",
    descripcion: "Estilo relaxed y cómodo. La comodidad nunca lució tan elegante.",
    precio: 79,
    categoria: "Relax",
    imagen: "/images/zapatos 07.jpg"
  },
  {
    id: 8,
    nombre: "Gliter Plata",
    descripcion: "Brillo sofisticado para ocasiones especiales. Brilla en cada momento importante.",
    precio: 95,
    categoria: "Fiesta",
    imagen: "/images/zapatos 08.jpg"
  },
  {
    id: 9,
    nombre: "Bella Plata",
    descripcion: "Elegancia en plateado. El color que eleva cualquier outfit.",
    precio: 89,
    categoria: "Elegantes",
    imagen: "/images/zapatos 09.jpg"
  },
  {
    id: 10,
    nombre: "Star Plata",
    descripcion: "Diseño estrellas con brillo. Para mujeres que nacieron para brillar.",
    precio: 92,
    categoria: "Fiesta",
    imagen: "/images/zapatos 10.jpg"
  },
  {
    id: 11,
    nombre: "Reptil",
    descripcion: "Textura de reptil exclusiva. Un statement de poder y distinción.",
    precio: 105,
    categoria: "Premium",
    imagen: "/images/zapatos 11.jpg"
  },
  {
    id: 12,
    nombre: "Bella",
    descripcion: "Clásico elegante en negro. El básico que toda mujer necesita.",
    precio: 85,
    categoria: "Elegantes",
    imagen: "/images/zapatos 12.jpg"
  },
  {
    id: 13,
    nombre: "Star",
    descripcion: "Diseño starring con brillo. Eleva tu look con actitud de estrella.",
    precio: 89,
    categoria: "Fiesta",
    imagen: "/images/zapatos 13.jpg"
