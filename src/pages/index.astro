---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Inicio">
  <Header />

  <main>
    <section class="hero">
      <div class="hero-background"></div>
      <div class="hero-content">
        <span class="hero-label">Nueva Temporada</span>
        <h1>Elegancia<br/>en Cada Paso</h1>
        <p class="hero-description">Zapatos de diseño exclusivos para la mujer sofisticada. Crafted with passion, designed for you.</p>
        <div class="hero-cta">
          <a href="/productos" class="btn-primary">Explorar Colección</a>
          <a href="/nosotros" class="btn-secondary">Nuestra Historia</a>
        </div>
      </div>
      <div class="hero-image-container">
        <div class="hero-image-frame">
          <img src="/images/zapatos 01.jpg" alt="Zapatillas elegantes de mujer" />
        </div>
        <div class="hero-accent"></div>
      </div>
    </section>

    <section class="intro">
      <div class="intro-content">
        <span class="section-label">Nuestra Esencia</span>
        <h2>Más que zapatos, una declaración de estilo</h2>
        <p>En Élégance creemos que el calzado perfecto eleva tu outfit y tu confianza. Cada modelo está diseñado para la mujer que sabe lo que quiere: calidad excepcional, diseño atemporal y comodidad incomparable.</p>
      </div>
    </section>

    <section class="features">
      <div class="features-header">
        <span class="section-label">Por Qué Elegirnos</span>
        <h2>La Perfección en Cada Detalle</h2>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Artesanía Italiana</h3>
          <p>Cada par es elaborado a mano por maestros zapateros italianos con más de 30 años de experiencia.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3>Diseño Atemporal</h3>
          <p>Diseños que trascienden tendencias. Inversiones de estilo que duran toda la vida.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3>Comodidad Excepcional</h3>
          <p>Diseñados para usarse todo el día. Tu confort es nuestra prioridad absoluta.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <h3>Materiales Premium</h3>
          <p>Cuero italiano de primera calidad, colores exclusivos y acabados perfectos.</p>
        </div>
      </div>
    </section>

    <section class="cta-banner">
      <div class="cta-content">
        <h2>Descubre tu próximo par perfecto</h2>
        <p>Explora nuestra colección de zapatos diseñados para la mujer que marca tendencia.</p>
        <a href="/productos" class="btn-primary">Ver Colección</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  main {
    flex: 1;
  }

  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-dorado);
    display: block;
    margin-bottom: 1rem;
  }

  .hero {
    min-height: 90vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 3rem;
    align-items: center;
    gap: 4rem;
    position: relative;
  }

  .hero-background {
    position: absolute;
    top: 0;
    right: 0;
    width: 50%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-rosa-suave) 0%, var(--color-crema-oscuro) 100%);
    z-index: -1;
    clip-path: polygon(15% 0, 100% 0, 100% 100%, 0% 100%);
  }

  .hero-label {
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-dorado);
    display: block;
    margin-bottom: 1.5rem;
  }

  .hero-content h1 {
    font-size: 4.5rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--color-negro);
  }

  .hero-description {
    font-size: 1.1rem;
    color: var(--color-gris-medio);
    max-width: 450px;
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }

  .hero-cta {
    display: flex;
    gap: 1.5rem;
  }

  .btn-primary {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: var(--color-negro);
    color: var(--color-blanco-puro);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border: 1px solid var(--color-negro);
    transition: all 0.4s ease;
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--color-negro);
  }

  .btn-secondary {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: transparent;
    color: var(--color-negro);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border: 1px solid var(--color-negro);
    transition: all 0.4s ease;
  }

  .btn-secondary:hover {
    background: var(--color-negro);
    color: var(--color-blanco-puro);
  }

  .hero-image-container {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-image-frame {
    position: relative;
    z-index: 1;
  }

  .hero-image-frame img {
    width: 100%;
    max-width: 450px;
    aspect-ratio: 3/4;
    object-fit: cover;
    box-shadow: var(--sombra-media);
  }

  .hero-accent {
    position: absolute;
    top: 2rem;
    right: 2rem;
    bottom: -2rem;
    left: -2rem;
    border: 1px solid var(--color-dorado);
    z-index: 0;
  }

  .intro {
    padding: 6rem 3rem;
    background: var(--color-blanco-puro);
  }

  .intro-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .intro-content h2 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    color: var(--color-negro);
  }

  .intro-content p {
    font-size: 1.1rem;
    color: var(--color-gris-medio);
    line-height: 1.9;
  }

  .features {
    padding: 5rem 3rem;
    background: var(--color-crema);
  }

  .features-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .features-header h2 {
    font-size: 2.2rem;
    color: var(--color-negro);
  }

  .features-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .feature-card {
    background: var(--color-blanco-puro);
    padding: 2.5rem 2rem;
    text-align: center;
    transition: all 0.4s ease;
    border: 1px solid transparent;
  }

  .feature-card:hover {
    transform: translateY(-8px);
    border-color: var(--color-dorado);
    box-shadow: var(--sombra-suave);
  }

  .feature-icon {
    color: var(--color-dorado);
    margin-bottom: 1.5rem;
  }

  .feature-card h3 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--color-negro);
  }

  .feature-card p {
    font-size: 0.9rem;
    color: var(--color-gris-medio);
    line-height: 1.7;
  }

  .cta-banner {
    padding: 5rem 3rem;
    background: var(--color-negro);
    text-align: center;
  }

  .cta-content h2 {
    font-size: 2rem;
    color: var(--color-blanco-puro);
    margin-bottom: 1rem;
  }

  .cta-content p {
    color: var(--color-gris-claro);
    margin-bottom: 2rem;
    font-size: 1.1rem;
  }

  .cta-banner .btn-primary {
    background: var(--color-dorado);
    border-color: var(--color-dorado);
    color: var(--color-negro);
  }

  .cta-banner .btn-primary:hover {
    background: transparent;
    color: var(--color-blanco-puro);
  }

  @media (max-width: 1024px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 3rem;
    }

    .hero-background {
      display: none;
    }

    .hero-content h1 {
      font-size: 3rem;
    }

    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 2rem 1.5rem;
    }

    .hero-content h1 {
      font-size: 2.5rem;
    }

    .hero-cta {
      flex-direction: column;
      gap: 1rem;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .intro-content h2 {
      font-size: 2rem;
    }

    .features-header h2 {
      font-size: 1.8rem;
    }
  }
</style>